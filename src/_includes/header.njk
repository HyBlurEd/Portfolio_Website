<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__logo">{{ site.shortTitle | upper }}</a>
    <nav class="site-nav" aria-label="Projects">
      {%- for p in site.navProjects %}
        <a href="{{ p.url }}"{% if page.url == p.url %} aria-current="page"{% endif %}>{{ p.label }}</a>
      {%- endfor %}
    </nav>
  </div>
</header>
